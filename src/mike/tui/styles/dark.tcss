/* Modern Dark Theme - Inspired by Claude Code */

Screen {
    background: #1a1a1a;
}

/* Welcome Screen - Minimal */
#welcome-container {
    width: 100%;
    height: 100%;
    align: center middle;
    background: #1a1a1a;
}

#welcome-logo {
    width: auto;
    height: auto;
    content-align: center middle;
    color: #d97757;
    text-style: bold;
    margin-bottom: 1;
}

#welcome-title {
    width: auto;
    height: auto;
    content-align: center middle;
    color: #6b6b6b;
    text-style: none;
    margin-bottom: 2;
}

#welcome-hint {
    width: auto;
    height: auto;
    content-align: center middle;
    color: #6b6b6b;
    text-style: dim;
}

/* Main Screen - Minimal */
#main-container {
    width: 100%;
    height: 100%;
    background: #1a1a1a;
}

#output-log {
    height: 1fr;
    background: #1a1a1a;
    color: #e5e5e5;
    padding: 1;
    border: none;
}

#output-log .rich-log--line {
    color: #e5e5e5;
}

#input-container {
    height: 1;
    background: #1a1a1a;
    padding: 0 1;
}

#input-prompt {
    width: auto;
    content-align: center middle;
    color: #d97757;
    text-style: bold;
}

#command-input {
    width: 1fr;
    background: #1a1a1a;
    color: #e5e5e5;
    border: none;
}

#command-input:focus {
    border: none;
}

/* Sessions Screen */
#sessions-title {
    text-align: center;
    text-style: bold;
    color: #d97757;
    height: 1;
    padding: 1 0;
}

#sessions-table {
    background: #252525;
    color: #e5e5e5;
    height: 1fr;
}

#sessions-table .datatable--header {
    background: #333333;
    color: #e5e5e5;
    text-style: bold;
}

#sessions-table .datatable--cursor {
    background: #3d3d3d;
}

#sessions-hints {
    height: 1;
    color: #6b6b6b;
    content-align: center middle;
}

/* Help Screen */
HelpScreen {
    align: center middle;
}

#help-container {
    width: 80;
    height: auto;
    max-height: 90%;
    background: #252525;
    border: solid #d97757;
    padding: 1 2;
}

#help-title {
    text-align: center;
    text-style: bold;
    color: #d97757;
}

#help-content {
    background: #1a1a1a;
}

#help-content .markdown {
    color: #e5e5e5;
}

#help-footer {
    text-align: center;
    color: #6b6b6b;
}

/* Logs Screen */
#logs-header {
    height: 3;
    background: #252525;
    padding: 0 1;
}

#logs-title {
    width: 10;
    text-style: bold;
    color: #d97757;
    content-align: center middle;
}

#level-select {
    width: 20;
    margin: 0 1;
}

#logs-controls {
    width: 1fr;
    color: #6b6b6b;
    content-align: right middle;
}

#log-viewer {
    height: 1fr;
    background: #1a1a1a;
    color: #e5e5e5;
    border: none;
    padding: 0 1;
}

/* Modal */
#modal-content {
    background: #252525;
    border: solid #d97757;
    padding: 1 2;
}

#modal-message {
    text-align: center;
    margin-bottom: 1;
    color: #e5e5e5;
}

/* Notifications */
#notifications {
    layer: notification;
    width: 40;
    height: auto;
    dock: top;
}

.notification {
    background: #252525;
    color: #e5e5e5;
    padding: 1;
    margin: 0 1 1 0;
    border: solid #d97757;
}

.notification.error {
    border: solid #ff6b6b;
}

.notification.warning {
    border: solid #f9ca24;
}

.notification.success {
    border: solid #6c5ce7;
}

/* Session Detail Screen */
#file-tree-container {
    width: 50%;
    height: 100%;
    border-right: solid #333333;
}

#files-header {
    text-style: bold;
    color: #d97757;
    height: 1;
    padding: 0 1;
}

#file-tree-widget {
    height: 1fr;
    background: #252525;
}

#file-tree-widget .tree--label {
    color: #e5e5e5;
}

#file-tree-widget .tree--cursor {
    background: #3d3d3d;
}

#session-info {
    width: 50%;
    height: 100%;
    padding: 0 1;
}

#detail-header {
    text-style: bold;
    color: #d97757;
    height: 1;
    padding: 0 1;
}

#detail-content {
    height: 1fr;
    background: #1a1a1a;
    color: #e5e5e5;
}

/* General Widgets */
Static {
    color: #e5e5e5;
}

Input {
    background: #252525;
    color: #e5e5e5;
    border: solid #333333;
}

Input:focus {
    border: solid #d97757;
}

DataTable {
    background: #252525;
    color: #e5e5e5;
}

DataTable .datatable--header {
    background: #333333;
    color: #e5e5e5;
    text-style: bold;
}

DataTable .datatable--cursor {
    background: #3d3d3d;
}

ListView {
    background: #252525;
}

ListItem {
    color: #e5e5e5;
}

ListItem:hover {
    background: #333333;
}

ListItem.--selected {
    background: #d97757;
    color: #1a1a1a;
    text-style: bold;
}

Select {
    background: #252525;
    color: #e5e5e5;
}
